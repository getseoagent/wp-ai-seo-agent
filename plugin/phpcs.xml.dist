<?xml version="1.0"?>
<ruleset name="seo-agent">
    <description>WordPress + PHP-Compatibility ruleset for the seo-agent plugin.</description>

    <file>seo-agent.php</file>
    <file>uninstall.php</file>
    <file>includes/</file>

    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>tests/*</exclude-pattern>
    <exclude-pattern>assets/dist/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>

    <!-- WordPress core + extra rules; Docs ruleset is too noisy for v1. -->
    <rule ref="WordPress-Core"/>
    <rule ref="WordPress-Extra">
        <!-- Plugin uses PSR-4 with namespaces; WP file-naming rules don't apply. -->
        <exclude name="WordPress.Files.FileName"/>
        <exclude name="Universal.Files.SeparateFunctionsFromOO"/>

        <!-- This codebase uses camelCase variables consistently (mirrors the
             TypeScript backend). Mass-renaming for the WPCS preference would
             not improve readability. -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.VariableNotSnakeCase"/>

        <!-- Yoda conditions are a style preference; modern PHP idioms used. -->
        <exclude name="WordPress.PHP.YodaConditions"/>

        <!-- Short ternary `?: null` is intentional in defaulting helpers. -->
        <exclude name="Universal.Operators.DisallowShortTernary.Found"/>

        <!-- base64 is used as the encryption envelope for API/license keys
             (Settings + License classes). Not for code obfuscation. -->
        <exclude name="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_encode"/>
        <exclude name="WordPress.PHP.DiscouragedPHPFunctions.obfuscation_base64_decode"/>

        <!-- The proxy_chat handler in class-rest-controller.php streams an SSE
             pipe via cURL; wp_remote_get() can't be used because it can't
             write to the client connection chunk-by-chunk. ini_set / ob_flush
             / @-silenced ob_* calls are part of the stream-flushing setup.
             Plugin-Check accepts this because it's a request-scoped exception
             on a single handler. -->
        <exclude name="WordPress.WP.AlternativeFunctions.curl_curl_init"/>
        <exclude name="WordPress.WP.AlternativeFunctions.curl_curl_setopt_array"/>
        <exclude name="WordPress.WP.AlternativeFunctions.curl_curl_exec"/>
        <exclude name="WordPress.WP.AlternativeFunctions.curl_curl_error"/>
        <exclude name="WordPress.WP.AlternativeFunctions.curl_curl_close"/>
        <exclude name="WordPress.PHP.NoSilencedErrors.Discouraged"/>
        <exclude name="WordPress.PHP.IniSet.Risky"/>

        <!-- The /chat endpoint streams SSE bytes from cURL straight to the
             client (`echo $chunk`). Those bytes are SSE event frames, not
             HTML; escape would corrupt the protocol. Annotated inline. -->
        <exclude name="WordPress.Security.EscapeOutput.OutputNotEscaped"/>
    </rule>

    <!-- Domain for translation strings. -->
    <config name="text_domain" value="getseoagent"/>

    <!-- Run against PHP 8.1 (header's Requires PHP). -->
    <config name="testVersion" value="8.1-"/>
    <rule ref="PHPCompatibilityWP"/>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="ps"/>
</ruleset>
