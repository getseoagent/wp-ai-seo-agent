PORT=8787
NODE_ENV=development
DATABASE_URL=postgres://seoagent:seoagent_dev_pwd@127.0.0.1:5432/seoagent
# Required by `bun test` (DB-backed tests). MUST point at a database different
# from DATABASE_URL — tests DROP TABLE in beforeAll. The runtime safeguard in
# src/tests/_helpers/test-db.ts refuses to start if these two are equal.
TEST_DATABASE_URL=postgres://seoagent:seoagent_dev_pwd@127.0.0.1:5432/seoagent_test
LICENSE_HMAC_SECRET=replace-me-with-32-char-random-string
WAYFORPAY_MERCHANT_ACCOUNT=replace-with-wfp-merchant-account
WAYFORPAY_MERCHANT_SECRET_KEY=replace-with-wfp-secret-key
WAYFORPAY_DOMAIN=www.seo-friendly.org
# JWT_SECRET signs both user-tokens (issued via /auth/token to the plugin
# bootstrap path) AND service-tokens (signed by the backend on every plugin
# REST call). Plugin verifies via the matching SEO_AGENT_JWT_SECRET constant
# in wp-config.php — the values must be identical.
JWT_SECRET=replace-me-with-32-char-random-string
JWT_TOKEN_TTL_SECONDS=86400
# Optional rotation acceptance window — set to the previous JWT_SECRET for one
# token-TTL after rotation, then unset.
# JWT_SECRET_PREVIOUS=
WP_BASE_URL=https://www.seo-friendly.org
